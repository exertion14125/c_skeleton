; @generated by CMake (GEN_DEFAULT_LOG_INI)
[LOG]
min_level=@LOG_MIN_LEVEL@
queue_cap=@LOG_QUEUE_CAP@
max_msg=@LOG_MAX_MSG@

[FILE]
log_file_path=@LOG_FILE_PATH@
remain_first=@LOG_FILE_REMAIN_FIRST@
max_size =@LOG_FILE_MAX_SIZES@
max_count=@LOG_FILE_MAX_FILES@
flush_lines=@LOG_FILE_FLUSH_LINES@
fsync_lines=@LOG_FILE_FSYNC_LINES@

[UDP]
ip=@LOG_UDP_IP@
port=@LOG_UDP_PORT@

[UI]
log_ui_enable = @LOG_UI_ENABLE@
uds_path=@LOG_UI_UDS_PATH@
uds_notify=@LOG_UI_UDS_NOTIFY@
enable_no_ui=@LOG_UI_ENABLE_NO_UI@